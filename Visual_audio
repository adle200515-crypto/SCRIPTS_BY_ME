local visualizerState = {
	sound = nil,
	bars = {},
	rotation = 0,
	orbitRadius = VisualizerConfig.DISTANCE_INITIAL,
	colorActual = VisualizerConfig.COLORS_PRESET[1].color,
	rgbMode = false,
	baseY = 0,
	saturation = VisualizerConfig.SATURATION_DEFAULT,
	frequency = VisualizerConfig.FREQUENCY_DEFAULT,
	volume = VisualizerConfig.VOLUME_DEFAULT,
}

-- ===== MOTOR AUTO-CORRECTIVO DEL VISUALIZADOR =====
local VisualEngine = {
	_connection = nil,
	_isActive = false,
}

-- Función para crear las barras
local function spawnAllBars()
	table.clear(visualizerState.bars)
	
	local char = player.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	
	visualizerState.baseY = hrp.Position.Y + VisualizerConfig.GROUND_HEIGHT
	
	for i = 1, VisualizerConfig.BARS do
		local part = Instance.new("Part")
		part.Name = "VisualizerBar"
		part.Anchored = true
		part.CanCollide = false
		part.Material = Enum.Material.Neon
		part.Size = Vector3.new(0.4, 1, 0.4)
		part.Color = visualizerState.colorActual or Color3.fromRGB(255, 170, 0)
		part.CastShadow = false
		part.Parent = Workspace
		visualizerState.bars[i] = part
	end
end

-- Función principal de renderizado
local function renderFrame(dt)
	if not visualizerState.sound or not visualizerState.sound.Parent then return end
	if not visualizerState.sound.IsPlaying then return end
	
	local char = player.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	
	local orbitRadius = visualizerState.orbitRadius
	local saturation = visualizerState.saturation
	local frequency = visualizerState.frequency
	local rgbMode = visualizerState.rgbMode
	local colorActual = visualizerState.colorActual
	local barCount = VisualizerConfig.BARS
	
	visualizerState.baseY = hrp.Position.Y + VisualizerConfig.GROUND_HEIGHT
	local baseY = visualizerState.baseY
	
	local loudness = visualizerState.sound.PlaybackLoudness
	local power = math.clamp(loudness / frequency, 0, saturation)
	
	visualizerState.rotation = visualizerState.rotation + (dt * (1 + power * 3))
	local rotation = visualizerState.rotation
	
	local hrpX = hrp.Position.X
	local hrpZ = hrp.Position.Z
	
	for i, part in ipairs(visualizerState.bars) do
		if not part or not part.Parent then continue end
		
		local angle = rotation + (i / barCount) * math.pi * 2
		local height = 1 + power * 4
		
		if rgbMode then
			part.Color = Color3.fromHSV((tick() * 0.25 + i / barCount) % 1, 1, 1)
		elseif colorActual then
			part.Color = colorActual
		end
		
		part.Size = Vector3.new(0.4, height, 0.4)
		
		local pos = Vector3.new(
			math.cos(angle) * orbitRadius,
			baseY + height * 0.5,
			math.sin(angle) * orbitRadius
		)
		
		part.CFrame = CFrame.new(hrpX, 0, hrpZ) * CFrame.new(pos)
	end
end

-- Iniciar el motor
function VisualEngine:Start()
	if self._isActive then return end
	
	self._connection = RunService.Heartbeat:Connect(function(dt)
		renderFrame(dt)
	end)
	
	-- Watchdog cada 2 segundos
	task.spawn(function()
		while self._isActive and self._connection do
			task.wait(2)
			
			if not self._isActive then break end
			
			if visualizerState.sound and visualizerState.sound.Parent and visualizerState.sound.IsPlaying then
				local aliveCount = 0
				for _, part in ipairs(visualizerState.bars) do
					if part and part.Parent then
						aliveCount = aliveCount + 1
					end
				end
				
				if aliveCount < VisualizerConfig.BARS then
					spawnAllBars()
				end
			end
			
			if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
				for _, part in ipairs(visualizerState.bars) do
					if part and part.Parent then
						part:Destroy()
					end
				end
				table.clear(visualizerState.bars)
			end
		end
	end)
	
	self._isActive = true
	print("🔧 Motor Visual iniciado")
end

-- Detener el motor
function VisualEngine:Stop()
	if self._connection then
		self._connection:Disconnect()
		self._connection = nil
	end
	self._isActive = false
	print("🔧 Motor Visual detenido")
end

-- Limpiar barras
function VisualEngine:ClearBars()
	for _, part in ipairs(visualizerState.bars) do
		if part and part.Parent then
			part:Destroy()
		end
	end
	table.clear(visualizerState.bars)
end

-- ===== FUNCIONES DEL VISUALIZADOR =====
local function clearVisualizer()
	VisualEngine:ClearBars()
	
	if visualizerState.sound then
		pcall(function()
			if visualizerState.sound.IsPlaying then
				visualizerState.sound:Stop()
			end
			visualizerState.sound:Destroy()
		end)
		visualizerState.sound = nil
	end
	
	visualizerState.rotation = 0
	visualizerState.baseY = 0
end

local function createVisualizer()
	if visualizerState.sound then
		pcall(function()
			if visualizerState.sound.IsPlaying then
				visualizerState.sound:Stop()
			end
			visualizerState.sound:Destroy()
		end)
		visualizerState.sound = nil
	end
	
	local char = player.Character
	if not char then return false end
	
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return false end
	
	local sound = Instance.new("Sound")
	sound.Looped = true
	sound.Volume = visualizerState.volume
	sound.Parent = hrp
	visualizerState.sound = sound
	
	spawnAllBars()
	
	if not VisualEngine._isActive then
		VisualEngine:Start()
	end
	
	return true
end


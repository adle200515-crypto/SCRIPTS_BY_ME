local function positionSubPanel(panel)
	local x = mainPanel.AbsolutePosition.X + mainWidth + 8
	if x + mainWidth > gui.AbsoluteSize.X then
		x = mainPanel.AbsolutePosition.X - mainWidth - 8
	end
	local y = mainPanel.AbsolutePosition.Y
	panel.Position = UDim2.new(0, math.max(0, x), 0, y)
end


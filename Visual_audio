local UIComponents = {}

function UIComponents:CreateFrame(parent, size, bgColor, cornerRadius)
	local frame = Instance.new("Frame")
	frame.Size = size
	frame.BackgroundColor3 = bgColor or UIConfig.THEME.SURFACE
	frame.BorderSizePixel = 0
	frame.BackgroundTransparency = 0
	frame.ClipsDescendants = true
	frame.Active = true
	frame.Visible = false
	frame.Parent = parent
	
	local corner = Instance.new("UICorner")
	corner.CornerRadius = cornerRadius or UIConfig.CORNER_RADIUS.MEDIUM
	corner.Parent = frame
	
	local stroke = Instance.new("UIStroke")
	stroke.Color = UIConfig.THEME.BORDER
	stroke.Thickness = 1
	stroke.Transparency = 0.3
	stroke.Parent = frame
	
	return frame
end

function UIComponents:CreateLabel(parent, textKey, font, size, color)
	local label = Instance.new("TextLabel")

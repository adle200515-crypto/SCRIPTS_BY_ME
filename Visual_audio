-- ===== REGISTRO DE TEXTOS =====
local UITextRegistry = {}

local function RegisterUIText(element, key, isPlaceholder)
	table.insert(UITextRegistry, {
		Element = element,
		Key = key,
		IsPlaceholder = isPlaceholder or false,
	})
end

local function UpdateAllUITexts()
	for _, entry in ipairs(UITextRegistry) do
		if entry.Element and entry.Element.Parent then
			local text = L(entry.Key)
			if entry.IsPlaceholder then
				entry.Element.PlaceholderText = text
			else
				entry.Element.Text = text
			end
		end
	end
	
	if distanceLabel then
		distanceLabel.Text = L("DISTANCE") .. visualizerState.orbitRadius
	end
end


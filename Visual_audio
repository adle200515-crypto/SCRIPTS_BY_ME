function UIComponents:CreateSlider(parent, minValue, maxValue, defaultValue, step)
	local sliderFrame = UIComponents:CreateFrame(parent, 
		UDim2.new(1, 0, 0, isMobile and 52 or 44),
		UIConfig.THEME.SURFACE_LIGHT,
		UIConfig.CORNER_RADIUS.SMALL
	)
	sliderFrame.Visible = true
	
	local valueDisplay = UIComponents:CreateLabel(sliderFrame, 
		tostring(defaultValue), 
		UIConfig.FONT.MONO, 
		UIConfig.FONT_SIZE.SMALL, 
		UIConfig.THEME.ACCENT
	)
	valueDisplay.Size = UDim2.new(0, 40, 0, 20)
	valueDisplay.Position = UDim2.new(1, -44, 0, isMobile and 16 or 12)
	valueDisplay.TextXAlignment = Enum.TextXAlignment.Right
	
	local track = Instance.new("Frame")
	track.Size = UDim2.new(1, -50, 0, isMobile and 6 or 4)
	track.Position = UDim2.new(0, 8, 0, isMobile and 24 or 20)
	track.BackgroundColor3 = UIConfig.THEME.BORDER
	track.BorderSizePixel = 0
	track.Parent = sliderFrame
	Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
	
	local fill = Instance.new("Frame")
	fill.Size = UDim2.new((defaultValue - minValue) / (maxValue - minValue), 0, 1, 0)
	fill.BackgroundColor3 = UIConfig.THEME.ACCENT
	fill.BorderSizePixel = 0
	fill.Parent = track
	Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
	
	local knobSize = isMobile and 24 or 18
	local knob = Instance.new("TextButton")
	knob.Size = UDim2.new(0, knobSize, 0, knobSize)
	knob.Position = UDim2.new((defaultValue - minValue) / (maxValue - minValue), -knobSize/2, 0, -knobSize/2 + 2)
	knob.Text = ""
	knob.BackgroundColor3 = UIConfig.THEME.ACCENT
	knob.BorderSizePixel = 0
	knob.Parent = track
	Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
	
	local currentValue = defaultValue
	local isDragging = false
	
	local function updateSlider(inputPosition)
		local relativeX = inputPosition.X - track.AbsolutePosition.X
		local clampedX = math.clamp(relativeX / track.AbsoluteSize.X, 0, 1)
		local rawValue = minValue + (maxValue - minValue) * clampedX
		currentValue = step and math.floor(rawValue / step + 0.5) * step or rawValue
		currentValue = math.clamp(currentValue, minValue, maxValue)
		
		fill.Size = UDim2.new((currentValue - minValue) / (maxValue - minValue), 0, 1, 0)
		knob.Position = UDim2.new((currentValue - minValue) / (maxValue - minValue), -knobSize/2, 0, -knobSize/2 + 2)
		valueDisplay.Text = tostring(currentValue)
	end
	
	knob.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or 
		   input.UserInputType == Enum.UserInputType.Touch then
			isDragging = true
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or 
		                  input.UserInputType == Enum.UserInputType.Touch) then
			updateSlider(input.Position)
		end
	end)
	
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or 
		   input.UserInputType == Enum.UserInputType.Touch then
			isDragging = false
		end
	end)
	
	return {
		Frame = sliderFrame,
		GetValue = function() return currentValue end,
		SetValue = function(val)
			currentValue = math.clamp(val, minValue, maxValue)
			fill.Size = UDim2.new((currentValue - minValue) / (maxValue - minValue), 0, 1, 0)
			knob.Position = UDim2.new((currentValue - minValue) / (maxValue - minValue), -knobSize/2, 0, -knobSize/2 + 2)
			valueDisplay.Text = tostring(currentValue)
		end,
		OnValueChanged = function(callback)
			knob:GetPropertyChangedSignal("Position"):Connect(function()
				callback(currentValue)
			end)
		end
	}
end

-- ===== FUNCIÓN DE ARRASTRE =====
local function MakeDraggable(frame)
	frame.Active = true
	
	local titleBar = frame:FindFirstChild("TitleBar")
	local dragArea = titleBar or frame
	
	local isDragging = false
	local dragStart = Vector2.zero
	local startPos = Vector2.zero
	
	dragArea.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or 
		   input.UserInputType == Enum.UserInputType.Touch then
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				local target = playerGui:GetGuiObjectAtPosition(input.Position.X, input.Position.Y)
				if target and target:IsA("TextButton") then
					return
				end
			end
			
			isDragging = true
			dragStart = input.Position
			startPos = Vector2.new(frame.Position.X.Offset, frame.Position.Y.Offset)
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or 
		                  input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			local screenSize = gui.AbsoluteSize
			local frameSize = frame.AbsoluteSize
			
			local newX = math.clamp(startPos.X + delta.X, -frameSize.X/2, screenSize.X - frameSize.X/2)
			local newY = math.clamp(startPos.Y + delta.Y, -frameSize.Y/2, screenSize.Y - frameSize.Y/2)
			
			frame.Position = UDim2.new(0, newX, 0, newY)
		end
	end)
	
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or 
		   input.UserInputType == Enum.UserInputType.Touch then
			isDragging = false
		end
	end)
end


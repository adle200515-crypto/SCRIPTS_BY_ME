-- SISTEMA DE TRANSICIÓN ENTRE PÁGINAS
-- ============================================
local pages = {HomePage, ScriptPage, HubPage, AdminPage, ConfigPage}
local buttons = {btnHome, btnScript, btnHub, btnAdmin, btnConfig}
local activeButton = nil

local function switchPage(index)
    if index == 4 then
        if not checkFeatureAccess("Admin") then
            return
        end
    end
    
    for i, page in ipairs(pages) do
        page.Visible = (i == index)
    end
    
    if activeButton then
        local oldStroke = activeButton:FindFirstChild("UIStroke")
        if oldStroke then
            oldStroke.Color = Color3.fromRGB(40, 40, 40)
        end
    end
    
    activeButton = buttons[index]
    local newStroke = activeButton:FindFirstChild("UIStroke")
    if newStroke then
        newStroke.Color = Color3.fromRGB(0, 200, 0)
    end
end

btnHome.MouseButton1Click:Connect(function() switchPage(1) end)
btnScript.MouseButton1Click:Connect(function() switchPage(2) end)
btnHub.MouseButton1Click:Connect(function() switchPage(3) end)
btnAdmin.MouseButton1Click:Connect(function() 
    if checkFeatureAccess("Admin") then
        switchPage(4)
    end
end)
btnConfig.MouseButton1Click:Connect(function() switchPage(5) end)

switchPage(1)


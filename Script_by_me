local function checkAccess()
    -- 1. Verificar si es Amigo (máxima prioridad)
    for _, amigoId in ipairs(AMIGOS) do
        if LocalPlayer.UserId == amigoId then
            isAmigo = true
            userLevel = "Amigo"
            break
        end
    end
    
    -- 2. Si no es amigo, verificar GamePass
    if not isAmigo then
        local success, hasPass = pcall(function()
            return MarketplaceService:UserOwnsGamePassAsync(LocalPlayer.UserId, PREMIUM_GAMEPASS_ID)
        end)
        
        if success and hasPass then
            isPremium = true
            userLevel = "Premium"
        else
            userLevel = "Free"
        end
    end
    
    return userLevel
end


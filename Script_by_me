local function getWrappedTextHeight(text, textSize, font, availableWidth)
    local bounds = TextService:GetTextSize(text or "", textSize, font, Vector2.new(availableWidth, math.huge))
    return math.ceil(bounds.Y)
end

function CreateNotification(titulo, mensaje, tipo, duracion)
    duracion = duracion or 5
    
    local notif = Instance.new("Frame")
    notif.Name = "Notif"
    notif.Size = UDim2.new(0, WIDTH, 0, 0)
    notif.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    notif.BackgroundTransparency = 0.1
    notif.BorderSizePixel = 0
    notif.ClipsDescendants = true
    notif.Parent = Holder
    notif.LayoutOrder = -os.clock()

    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 2
    stroke.Color = Color3.fromRGB(20, 20, 20)
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = notif

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = notif

    local icon = Instance.new("ImageLabel")
    icon.Size = UDim2.new(0, 40, 0, 40)
    icon.Position = UDim2.new(0, 10, 0, 15)
    icon.BackgroundTransparency = 1
    icon.Parent = notif
    icon.Image = (tipo == "Error" and ErrorIcon) or (tipo == "Warning" and WarningIcon) or (tipo == "Premium" and PremiumIcon) or (tipo == "LOL" and LolIcon) or SuccessIcon

    local titleL = Instance.new("TextLabel")
    titleL.Size = UDim2.new(1, -LEFT_OFFSET, 0, TITLE_HEIGHT)
    titleL.Position = UDim2.new(0, LEFT_OFFSET, 0, 10)
    titleL.BackgroundTransparency = 1
    titleL.Text = titulo or "Notificación"
    titleL.TextColor3 = (tipo == "Premium") and Color3.fromRGB(255, 215, 0) or Color3.fromRGB(255, 255, 255)
    titleL.Font = Enum.Font.GothamBold
    titleL.TextSize = 14
    titleL.TextXAlignment = Enum.TextXAlignment.Left
    titleL.Parent = notif

    local desc = Instance.new("TextLabel")
    desc.Size = UDim2.new(1, -LEFT_OFFSET, 0, 0)
    desc.Position = UDim2.new(0, LEFT_OFFSET, 0, DESC_TOP)
    desc.BackgroundTransparency = 1
    desc.Text = mensaje or ""
    desc.TextColor3 = Color3.fromRGB(200, 200, 200)
    desc.Font = Enum.Font.Gotham
    desc.TextSize = 13
    desc.TextWrapped = true
    desc.TextXAlignment = Enum.TextXAlignment.Left
    desc.TextYAlignment = Enum.TextYAlignment.Top
    desc.Parent = notif

    local availableWidth = WIDTH - LEFT_OFFSET - 10
    local descH = getWrappedTextHeight(desc.Text, desc.TextSize, desc.Font, availableWidth)
    desc.Size = UDim2.new(1, -LEFT_OFFSET, 0, descH)

    local needH = math.max(MIN_HEIGHT, DESC_TOP + descH + BOTTOM_PADDING)

    local timeBar = Instance.new("Frame")
    timeBar.Size = UDim2.new(1, 0, 0, BAR_HEIGHT)
    timeBar.Position = UDim2.new(0, 0, 1, -BAR_HEIGHT)
    timeBar.BackgroundColor3 = (tipo == "Premium") and Color3.fromRGB(255, 215, 0) or (tipo == "LOL") and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(0, 170, 255)
    timeBar.BorderSizePixel = 0
    timeBar.Parent = notif

    local barCorner = Instance.new("UICorner")
    barCorner.CornerRadius = UDim.new(1, 0)
    barCorner.Parent = timeBar

    local s = Instance.new("Sound")
    s.SoundId = "rbxassetid://4590657391"
    s.Volume = 1
    s.Parent = notif
    s:Play()

    TweenService:Create(notif, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        { Size = UDim2.new(0, WIDTH, 0, needH) }):Play()

    TweenService:Create(timeBar, TweenInfo.new(duracion, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
        { Size = UDim2.new(0, 0, 0, BAR_HEIGHT) }):Play()

    task.delay(duracion, function()
        TweenService:Create(notif, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            { Size = UDim2.new(0, WIDTH, 0, 0) }):Play()
        task.wait(0.22)
        notif:Destroy()
    end)
end


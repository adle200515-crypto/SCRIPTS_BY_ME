    btn.Size = UDim2.new(width or 0.45, 0, 0, 35)
    btn.BackgroundColor3 = color or Color3.fromRGB(30, 30, 30)
    btn.BackgroundTransparency = 0.2
    btn.BorderSizePixel = 0
    btn.Text = text
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 12
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Parent = parent
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = btn
    
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 1
    stroke.Color = Color3.fromRGB(0, 150, 0)
    stroke.Parent = btn
    
    if callback then
        btn.MouseButton1Click:Connect(callback)
    end
    
    return btn
end

-- Función para crear dropdown de jugadores (CORREGIDO)
local function createPlayerDropdown(parent, placeholder)
    local dropdown = Instance.new("Frame")
    dropdown.Size = UDim2.new(0.45, 0, 0, 35)
    dropdown.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    dropdown.BackgroundTransparency = 0.2
    dropdown.BorderSizePixel = 0
    dropdown.Parent = parent
    dropdown.ZIndex = 10
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = dropdown
    
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 1
    stroke.Color = Color3.fromRGB(0, 150, 0)
    stroke.Parent = dropdown
    
    local selectedText = Instance.new("TextLabel")
    selectedText.Size = UDim2.new(1, -30, 1, 0)
    selectedText.Position = UDim2.new(0, 10, 0, 0)
    selectedText.BackgroundTransparency = 1
    selectedText.Text = placeholder or "Seleccionar jugador"
    selectedText.Font = Enum.Font.Gotham
    selectedText.TextSize = 12
    selectedText.TextColor3 = Color3.fromRGB(200, 200, 200)
    selectedText.TextXAlignment = Enum.TextXAlignment.Left
    selectedText.Parent = dropdown
    selectedText.ZIndex = 10
    
    local arrow = Instance.new("TextLabel")
    arrow.Size = UDim2.new(0, 20, 1, 0)
    arrow.Position = UDim2.new(1, -25, 0, 0)
    arrow.BackgroundTransparency = 1
    arrow.Text = "▼"
    arrow.Font = Enum.Font.Gotham
    arrow.TextSize = 14
    arrow.TextColor3 = Color3.fromRGB(0, 200, 0)
    arrow.Parent = dropdown
    arrow.ZIndex = 10
    
    local playerListContainer = Instance.new("Frame")
    playerListContainer.Size = UDim2.new(1, 0, 0, 150)
    playerListContainer.Position = UDim2.new(0, 0, 1, 5)
    playerListContainer.BackgroundTransparency = 1
    playerListContainer.Visible = false
    playerListContainer.Parent = dropdown
    playerListContainer.ZIndex = 100
    
    local playerList = Instance.new("ScrollingFrame")
    playerList.Size = UDim2.new(1, 0, 1, 0)
    playerList.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    playerList.BorderSizePixel = 0
    playerList.Parent = playerListContainer
    playerList.ZIndex = 100
    playerList.ScrollBarThickness = 4
    playerList.ScrollBarImageColor3 = Color3.fromRGB(0, 150, 0)
    playerList.CanvasSize = UDim2.new(0, 0, 0, 0)
    
    local listCorner = Instance.new("UICorner")
    listCorner.CornerRadius = UDim.new(0, 6)
    listCorner.Parent = playerList
    
    local listLayout = Instance.new("UIListLayout")
    listLayout.Parent = playerList
    listLayout.SortOrder = Enum.SortOrder.Name
    listLayout.Padding = UDim.new(0, 2)
    
    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        playerList.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y)
    end)
    
    local selectedPlayer = nil
    
    local function refreshPlayerList()
        for _, child in ipairs(playerList:GetChildren()) do
            if child:IsA("TextButton") or child:IsA("TextLabel") then
                child:Destroy()
            end
        end
        
        local players = Players:GetPlayers()
        local hasPlayers = false
        
        for _, plr in ipairs(players) do
            if plr ~= LocalPlayer then
                hasPlayers = true
                local btn = Instance.new("TextButton")
                btn.Size = UDim2.new(1, -4, 0, 30)
                btn.Position = UDim2.new(0, 2, 0, 0)
                btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
                btn.Text = plr.Name .. (plr == selectedPlayer and " ✓" or "")
                btn.Font = Enum.Font.Gotham
                btn.TextSize = 12
                btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                btn.Parent = playerList
                btn.ZIndex = 100
                
                local btnCorner = Instance.new("UICorner")
                btnCorner.CornerRadius = UDim.new(0, 4)
                btnCorner.Parent = btn
                
                btn.MouseButton1Click:Connect(function()
                    selectedPlayer = plr
                    selectedText.Text = plr.Name
                    playerListContainer.Visible = false
                    refreshPlayerList()
                end)
            end
        end
        
        if not hasPlayers then
            local noPlayersLabel = Instance.new("TextLabel")
            noPlayersLabel.Size = UDim2.new(1, -4, 0, 30)
            noPlayersLabel.Position = UDim2.new(0, 2, 0, 0)
            noPlayersLabel.BackgroundTransparency = 1
            noPlayersLabel.Text = "No hay jugadores"
            noPlayersLabel.Font = Enum.Font.Gotham
            noPlayersLabel.TextSize = 12
            noPlayersLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
            noPlayersLabel.Parent = playerList
        end
    end
    
    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Size = UDim2.new(1, 0, 1, 0)
    toggleBtn.BackgroundTransparency = 1
    toggleBtn.Text = ""
    toggleBtn.Parent = dropdown
    toggleBtn.ZIndex = 10
    
    toggleBtn.MouseButton1Click:Connect(function()
        refreshPlayerList()
        playerListContainer.Visible = not playerListContainer.Visible
    end)
    
    local function closeDropdown()
        playerListContainer.Visible = false
    end
    
    local connection
    connection = UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mousePos = UserInputService:GetMouseLocation()
            local guiObjects = CoreGui:GetGuiObjectsAtPosition(mousePos.X, mousePos.Y)
            local clickedInside = false
            
            for _, obj in ipairs(guiObjects) do
                if obj:IsDescendantOf(dropdown) then
                    clickedInside = true
                    break
                end
            end
            
            if not clickedInside then
                closeDropdown()
            end
        end
    end)
    
    task.spawn(function()
        while dropdown and dropdown.Parent do
            if playerListContainer.Visible then
                refreshPlayerList()
            end
            task.wait(5)
        end
    end)
    
    Players.PlayerAdded:Connect(function()
        if playerListContainer.Visible then
            refreshPlayerList()
        end
    end)
    
    Players.PlayerRemoving:Connect(function(plr)
        if selectedPlayer == plr then
            selectedPlayer = nil
            selectedText.Text = placeholder or "Seleccionar jugador"
        end
        if playerListContainer.Visible then
            refreshPlayerList()
        end
    end)
    
    return {
        Frame = dropdown,
        GetSelected = function() return selectedPlayer end,
        SetSelected = function(plr) 
            selectedPlayer = plr 
            selectedText.Text = plr and plr.Name or placeholder
        end,
        Refresh = refreshPlayerList,
        Close = closeDropdown
    }
end

-- Función para crear input de texto
local function createTextInput(parent, placeholder, width)
    local input = Instance.new("TextBox")
    input.Size = UDim2.new(width or 0.45, 0, 0, 35)
    input.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    input.BackgroundTransparency = 0.2
    input.BorderSizePixel = 0
    input.Text = ""
    input.PlaceholderText = placeholder or "Escribe aquí..."
    input.PlaceholderColor3 = Color3.fromRGB(150, 150, 150)
    input.Font = Enum.Font.Gotham
    input.TextSize = 12
    input.TextColor3 = Color3.fromRGB(255, 255, 255)
    input.Parent = parent
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = input
    
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 1
    stroke.Color = Color3.fromRGB(0, 150, 0)
    stroke.Parent = input
    
    return input
end

-- Función para obtener jugador objetivo
local function getTargetPlayer(dropdown)
    if dropdown then
        return dropdown.GetSelected() or LocalPlayer
    end
    return LocalPlayer
end


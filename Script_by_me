local scriptButtons = {}

-- Crear botones del Hub
for idx, name in ipairs(buttonNames) do
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Text = ""
    btn.Size = UDim2.new(0.96, 0, 0, 35)
    btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    btn.BackgroundTransparency = 0.3
    btn.Parent = HubScroll
    btn.LayoutOrder = idx + 3
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = btn
    
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 1
    stroke.Color = Color3.fromRGB(0, 150, 0)
    stroke.Parent = btn
    
    local lbl = Instance.new("TextLabel")
    lbl.Text = name
    lbl.Size = UDim2.new(1, -10, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = Color3.new(1, 1, 1)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = btn
    
    -- Verificar si es script premium
    local isPremiumScript = false
    for _, premiumName in ipairs(PREMIUM_SCRIPTS) do
        if name == premiumName then
            isPremiumScript = true
            break
        end
    end
    
    -- Añadir icono de candado si es premium
    if isPremiumScript then
        local lockIcon = Instance.new("TextLabel")
        lockIcon.Size = UDim2.new(0, 20, 1, 0)
        lockIcon.Position = UDim2.new(1, -25, 0, 0)
        lockIcon.BackgroundTransparency = 1
        lockIcon.Text = "🔒"
        lockIcon.Font = Enum.Font.Gotham
        lockIcon.TextSize = 14
        lockIcon.TextColor3 = Color3.fromRGB(255, 200, 0)
        lockIcon.Parent = btn
    end
    
    local func = buttonFunctions[name]
    if func then
        btn.MouseButton1Click:Connect(function()
            if isPremiumScript then
                if checkFeatureAccess("PremiumScript") then
                    func()
                end
            else
                func()
            end
        end)
    end
    
    table.insert(scriptButtons, {button = btn, name = name, isPremium = isPremiumScript})
end

ResultCount.Text = "Total: " .. #scriptButtons .. " scripts"

-- Función de búsqueda
local function filterScripts(searchText)
    local visibleCount = 0
    searchText = searchText:lower()
    
    for _, data in ipairs(scriptButtons) do
        local btn = data.button
        local name = data.name:lower()
        
        if searchText == "" or searchText == "🔍 buscar script..." or name:find(searchText, 1, true) then
            btn.Visible = true
            visibleCount = visibleCount + 1
        else
            btn.Visible = false
        end
    end
    
    ResultCount.Text = "Mostrando: " .. visibleCount .. " / " .. #scriptButtons .. " scripts"
    HubScroll.CanvasSize = UDim2.new(0, 0, 0, HubList.AbsoluteContentSize.Y)
end

